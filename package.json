{
  "name": "openaistudio-vllm-agent",
  "displayName": "OpenAIStudio vLLM Agent",
  "description": "AI Assistant using local vLLM for software development",
  "version": "0.0.1",
  "publisher": "yuriikucherenko",
  "repository": {
    "type": "git",
    "url": "https://github.com/uraalexkuch/openaistudio-vllm-agent"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "openaistudio.openAgent",
        "title": "OpenAIStudio: Відкрити чат агента"
      },
      {
        "command": "openaistudio.newTask",
        "title": "OpenAIStudio: Нове завдання (Проєкт)"
      },
      {
        "command": "openaistudio.openSettings",
        "title": "OpenAIStudio: Налаштування"
      },
      {
        "command": "openaistudio.stopAgent",
        "title": "OpenAIStudio: Зупинити агента"
      },
      {
        "command": "openaistudio.selectModel",
        "title": "OpenAIStudio: Обрати модель vLLM"
      },
      {
        "command": "openaistudio.syncSkills",
        "title": "OpenAIStudio: Синхронізувати скіли (Skills)"
      },
      {
        "command": "openaistudio.explainFile",
        "title": "OpenAIStudio: Пояснити файл/код"
      },
      {
        "command": "openaistudio.fixSelection",
        "title": "OpenAIStudio: Виправити помилки"
      },
      {
        "command": "openaistudio.refactor",
        "title": "OpenAIStudio: Рефакторинг (Clean Code)"
      },
      {
        "command": "openaistudio.writeTests",
        "title": "OpenAIStudio: Написати тести"
      },
      {
        "command": "openaistudio.implement",
        "title": "OpenAIStudio: Реалізувати функціонал"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "openaistudio.explainFile",
          "group": "openaistudio@1"
        },
        {
          "command": "openaistudio.fixSelection",
          "group": "openaistudio@2",
          "when": "editorHasSelection"
        },
        {
          "command": "openaistudio.refactor",
          "group": "openaistudio@3",
          "when": "editorHasSelection"
        },
        {
          "command": "openaistudio.writeTests",
          "group": "openaistudio@4",
          "when": "editorHasSelection"
        },
        {
          "command": "openaistudio.implement",
          "group": "openaistudio@5",
          "when": "editorHasSelection"
        }
      ]
    },
    "configuration": {
      "title": "OpenAIStudio",
      "properties": {
        "openaistudio.vllmUrl": {
          "type": "string",
          "default": "http://10.1.0.102:8050",
          "description": "Базовий URL вашого vLLM сервера БЕЗ /v1 в кінці. Код автоматично додає /<model>/v1 до кожного запиту. Приклад: http://10.1.0.102:8050"
        },
        "openaistudio.apiKey": {
          "type": "string",
          "default": "EMPTY",
          "description": "API ключ для vLLM (зазвичай EMPTY для локального сервера)"
        },
        "openaistudio.perplexicaUrl": {
          "type": "string",
          "default": "",
          "description": "URL локального сервера Perplexica для веб-пошуку агентів. Приклад: http://localhost:3001"
        },
        "openaistudio.skillsPath": {
          "type": "string",
          "default": "",
          "description": "Повний шлях до директорії зі скілами (SKILL.md файлами). Приклад: C:\\Users\\User\\Documents\\antigravity-awesome-skills"
        },
        "openaistudio.modelRouter": {
          "type": "string",
          "default": "gemma",
          "markdownDescription": "**Model name** для CEO / аналізу задачі (повертає JSON). Сервер: `gemma` → 2.1s, 16384 токенів. Mistral виключено через обмеження 4096 токенів."
        },
        "openaistudio.modelCodeHeavy": {
          "type": "string",
          "default": "codestral",
          "markdownDescription": "**nginx path** для складного коду (Complexity=High). Сервер: `codestral` → 1.969s, 32768 токенів."
        },
        "openaistudio.modelCodeLight": {
          "type": "string",
          "default": "qwen3-coder",
          "markdownDescription": "**Model name** для швидкого коду (Complexity=Low) та code review. Сервер: `qwen3-coder` → 0.765s, 32768 токенів. URL: `/qwen3-coder/v1`"
        },
        "openaistudio.modelGeneral": {
          "type": "string",
          "default": "gemma",
          "markdownDescription": "**nginx path** для загальних ролей (Technical Writer, CPO, документація). Сервер: `gemma` → 2.123s, 16384 токенів."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "compile": "npm run esbuild-base",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.4",
    "eslint": "^8.41.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "openai": "^4.104.0"
  }
}